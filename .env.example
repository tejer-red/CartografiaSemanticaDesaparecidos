# .env.example
# -------------------------------------------------
# Legacy MySQL (or MariaDB) connection parameters
# -------------------------------------------------
OLD_DB_HOST=your_mysql_host
OLD_DB_USER=your_mysql_user
OLD_DB_PASSWORD=your_mysql_password
OLD_DB_NAME=your_mysql_db
OLD_DB_PORT=3306

# -------------------------------------------------
# Target PostgreSQL (Supabase) connection string
# -------------------------------------------------
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE
NEW_DATABASE_URL=postgresql://your_pg_user:your_pg_password@your_pg_host:5432/your_pg_db

# -------------------------------------------------
# FastAPI server settings
# -------------------------------------------------
DATABASE_URL=postgresql://your_pg_user:your_pg_password@your_pg_host:5432/your_pg_db

# -------------------------------------------------
# Supabase Auth
# -------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
